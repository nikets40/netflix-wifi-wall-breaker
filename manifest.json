{
  "manifest_version": 3,
  "name": "Netflix WiFi Wall Breaker",
  "version": "1.0.0",
  "description": "Removes divs from Netflix body until appMountPoint to bypass WiFi restrictions",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["https://www.netflix.com/*", "https://netflix.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*", "https://netflix.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Netflix WiFi Wall Breaker"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
